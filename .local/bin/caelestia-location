#!/usr/bin/env python3
import argparse
import datetime as dt
import hashlib
import json
import os
import secrets
import subprocess
import sys
import urllib.error
import urllib.request


PRESETS = {
    "huilongguan": {
        "name": "Huilongguan",
        "loc": "40.0631,116.3185",
        "accuracy_m": 8000,
    },
    "zhongguancun": {
        "name": "Zhongguancun",
        "loc": "39.9767,116.3123",
        "accuracy_m": 6000,
    },
    "jingxing": {
        "name": "Jingxing County",
        "loc": "38.0327,114.1355",
        "accuracy_m": 15000,
    },
    "beijing": {
        "name": "Beijing",
        "loc": "39.9042,116.4074",
        "accuracy_m": 30000,
    },
}

STATE_HOME = os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state"))
CONFIG_HOME = os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config"))
STATE_DIR = os.path.join(STATE_HOME, "caelestia")
CONFIG_DIR = os.path.join(CONFIG_HOME, "caelestia")
FINGERPRINTS_PATH = os.path.join(STATE_DIR, "location-fingerprints.json")
SALT_PATH = os.path.join(STATE_DIR, "location-salt")
PRESETS_PATH = os.path.join(CONFIG_DIR, "location-presets.json")


def now_iso():
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat()


def ensure_state_dir():
    os.makedirs(STATE_DIR, mode=0o700, exist_ok=True)


def load_extra_presets():
    if not os.path.exists(PRESETS_PATH):
        return {}
    with open(PRESETS_PATH, "r", encoding="utf-8") as f:
        data = json.load(f)
    if not isinstance(data, dict):
        raise ValueError(f"{PRESETS_PATH} must contain a JSON object")
    return data


def all_presets():
    presets = dict(PRESETS)
    presets.update(load_extra_presets())
    return presets


def load_salt():
    ensure_state_dir()
    if os.path.exists(SALT_PATH):
        with open(SALT_PATH, "r", encoding="utf-8") as f:
            return f.read().strip()
    salt = secrets.token_hex(32)
    with open(SALT_PATH, "w", encoding="utf-8") as f:
        f.write(salt + "\n")
    os.chmod(SALT_PATH, 0o600)
    return salt


def hash_bssid(bssid, salt):
    normalized = bssid.strip().lower()
    return hashlib.sha256((salt + ":" + normalized).encode("utf-8")).hexdigest()


def scan_wifi(rescan=False, max_aps=40):
    cmd = ["nmcli", "-t", "--escape", "no", "-f", "BSSID,SIGNAL", "dev", "wifi", "list"]
    if rescan:
        cmd.extend(["--rescan", "yes"])
    try:
        raw = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL, timeout=20)
    except Exception:
        return []

    aps = []
    seen = set()
    for line in raw.splitlines():
        if not line.strip():
            continue
        parts = line.rsplit(":", 1)
        if len(parts) != 2:
            continue
        bssid = parts[0].strip()
        if not bssid or bssid in seen:
            continue
        seen.add(bssid)
        try:
            signal = int(parts[1].strip())
        except ValueError:
            signal = 0
        aps.append({"bssid": bssid, "signal": signal})

    aps.sort(key=lambda ap: ap["signal"], reverse=True)
    return aps[:max_aps]


def fingerprint_from_scan(aps):
    salt = load_salt()
    return [hash_bssid(ap["bssid"], salt) for ap in aps]


def load_db():
    if not os.path.exists(FINGERPRINTS_PATH):
        return {"version": 1, "fingerprints": []}
    with open(FINGERPRINTS_PATH, "r", encoding="utf-8") as f:
        data = json.load(f)
    if "fingerprints" not in data or not isinstance(data["fingerprints"], list):
        return {"version": 1, "fingerprints": []}
    return data


def save_db(db):
    ensure_state_dir()
    with open(FINGERPRINTS_PATH, "w", encoding="utf-8") as f:
        json.dump(db, f, indent=2, sort_keys=True)
        f.write("\n")
    os.chmod(FINGERPRINTS_PATH, 0o600)


def preset_result(key, source, score=None, shared_aps=None):
    presets = all_presets()
    preset = presets[key]
    result = {
        "ok": True,
        "source": source,
        "preset": key,
        "name": preset["name"],
        "loc": preset["loc"],
        "accuracy_m": preset.get("accuracy_m", 15000),
    }
    if score is not None:
        result["score"] = round(score, 3)
    if shared_aps is not None:
        result["shared_aps"] = shared_aps
    return result


def match_fingerprint(current_hashes):
    current = set(current_hashes)
    if len(current) < 3:
        return None

    db = load_db()
    best = None
    for fp in db.get("fingerprints", []):
        preset = fp.get("preset")
        stored = set(fp.get("aps", []))
        if not preset or not stored:
            continue
        shared = len(current & stored)
        if shared == 0:
            continue
        containment = shared / max(1, min(len(current), len(stored)))
        jaccard = shared / max(1, len(current | stored))
        score = max(containment, jaccard)
        candidate = {
            "preset": preset,
            "score": score,
            "shared": shared,
            "stored_count": len(stored),
        }
        if best is None or (candidate["shared"], candidate["score"]) > (best["shared"], best["score"]):
            best = candidate

    if not best:
        return None
    if best["shared"] >= 4 or (best["shared"] >= 3 and best["score"] >= 0.18):
        return best
    return None


def ipinfo_fallback():
    try:
        with urllib.request.urlopen("https://ipinfo.io/json", timeout=12) as r:
            data = json.loads(r.read().decode("utf-8"))
    except Exception as e:
        return {
            "ok": False,
            "source": "none",
            "error": f"ipinfo failed: {type(e).__name__}",
        }

    loc = data.get("loc") or ""
    city = data.get("city") or ""
    region = data.get("region") or ""
    country = data.get("country") or ""
    if country and country != "CN":
        result = preset_result("beijing", "ipinfo-vpn-guard")
        result["ipinfo_city"] = city
        result["ipinfo_region"] = region
        result["ipinfo_country"] = country
        return result
    return {
        "ok": bool(loc),
        "source": "ipinfo",
        "name": city or region or country or "Unknown",
        "city": city,
        "region": region,
        "country": country,
        "loc": loc,
        "accuracy_m": 25000,
    }


def cmd_auto(args):
    aps = scan_wifi(rescan=args.rescan, max_aps=args.max_aps)
    hashes = fingerprint_from_scan(aps)
    match = match_fingerprint(hashes)
    if match:
        result = preset_result(match["preset"], "known-wifi", match["score"], match["shared"])
        result["wifi_ap_count"] = len(aps)
    else:
        result = ipinfo_fallback()
        result["wifi_ap_count"] = len(aps)
    result["updated_at"] = now_iso()
    print(json.dumps(result, ensure_ascii=False))


def cmd_learn(args):
    presets = all_presets()
    if args.preset not in presets:
        print(f"Unknown preset: {args.preset}", file=sys.stderr)
        print("Known presets: " + ", ".join(sorted(presets)), file=sys.stderr)
        return 2

    aps = scan_wifi(rescan=True, max_aps=args.max_aps)
    if len(aps) < 3:
        print("Not enough Wi-Fi access points to learn this location.", file=sys.stderr)
        return 1

    hashes = fingerprint_from_scan(aps)
    db = load_db()
    db.setdefault("version", 1)
    db.setdefault("fingerprints", [])
    db["fingerprints"].append({
        "preset": args.preset,
        "created_at": now_iso(),
        "ap_count": len(hashes),
        "aps": hashes,
    })
    save_db(db)
    print(json.dumps({
        "ok": True,
        "learned": args.preset,
        "name": presets[args.preset]["name"],
        "ap_count": len(hashes),
        "stored": FINGERPRINTS_PATH,
    }, ensure_ascii=False))
    return 0


def cmd_status(args):
    aps = scan_wifi(rescan=args.rescan, max_aps=args.max_aps)
    hashes = fingerprint_from_scan(aps)
    match = match_fingerprint(hashes)
    db = load_db()
    result = {
        "wifi_ap_count": len(aps),
        "fingerprint_count": len(db.get("fingerprints", [])),
        "match": match,
        "state_file": FINGERPRINTS_PATH,
    }
    print(json.dumps(result, ensure_ascii=False, indent=2))


def cmd_list(args):
    print(json.dumps(all_presets(), ensure_ascii=False, indent=2, sort_keys=True))


def cmd_forget(args):
    db = load_db()
    before = len(db.get("fingerprints", []))
    db["fingerprints"] = [fp for fp in db.get("fingerprints", []) if fp.get("preset") != args.preset]
    save_db(db)
    print(json.dumps({"ok": True, "removed": before - len(db["fingerprints"]), "preset": args.preset}, ensure_ascii=False))


def main():
    parser = argparse.ArgumentParser(description="Coarse local location provider for Caelestia.")
    sub = parser.add_subparsers(dest="command")

    p_auto = sub.add_parser("auto", help="Print current best location as JSON.")
    p_auto.add_argument("--json", action="store_true", help="Kept for readability; output is always JSON.")
    p_auto.add_argument("--rescan", action="store_true", help="Ask NetworkManager to rescan before matching.")
    p_auto.add_argument("--max-aps", type=int, default=40)
    p_auto.set_defaults(func=cmd_auto)

    p_learn = sub.add_parser("learn", help="Learn current Wi-Fi fingerprint for a preset.")
    p_learn.add_argument("preset")
    p_learn.add_argument("--max-aps", type=int, default=40)
    p_learn.set_defaults(func=cmd_learn)

    p_status = sub.add_parser("status", help="Show sanitized matching status.")
    p_status.add_argument("--rescan", action="store_true")
    p_status.add_argument("--max-aps", type=int, default=40)
    p_status.set_defaults(func=cmd_status)

    p_list = sub.add_parser("list", help="List known presets.")
    p_list.set_defaults(func=cmd_list)

    p_forget = sub.add_parser("forget", help="Remove learned fingerprints for a preset.")
    p_forget.add_argument("preset")
    p_forget.set_defaults(func=cmd_forget)

    args = parser.parse_args()
    if not args.command:
        args = parser.parse_args(["auto"])
    rc = args.func(args)
    return 0 if rc is None else rc


if __name__ == "__main__":
    raise SystemExit(main())
